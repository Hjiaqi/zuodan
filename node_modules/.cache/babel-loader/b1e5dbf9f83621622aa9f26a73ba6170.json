{prodName}</td>\r\n    </tr>   \r\n</table>`;\r\n};\r\n\r\n//图片空行\r\nexport const imgEmptyLeftTable = `<table  align=\"center\" >\r\n<tr align=\"center\" valign=\"center\">\r\n    <td > </td>\r\n</tr>\r\n<tr align=\"center\">\r\n    <td ></td>\r\n</tr>\r\n<tr align=\"center\">\r\n    <td ></td>\r\n</tr>\r\n</table>${emptyBottomTable}`;\r\n\r\n//-----------做单的-----------\r\nexport const emptyLeftTable = `<table  align=\"center\" >\r\n<colgroup>\r\n    <col span=\"1\"style=\"\">\r\n  </colgroup>\r\n<tr align=\"center\" valign=\"center\">\r\n    <td > </td>\r\n</tr>\r\n<tr align=\"center\">\r\n    <td ></td>\r\n</tr>\r\n<tr align=\"center\">\r\n    <td></td>\r\n</tr>\r\n<tr align=\"center\">\r\n    <td></td>\r\n</tr>\r\n<tr align=\"center\">\r\n    <td></td>\r\n</tr>\r\n<tr align=\"center\">\r\n    <td></td>\r\n</tr>\r\n<tr align=\"center\">\r\n    <td></td>\r\n</tr>\r\n<tr align=\"center\">\r\n    <td></td>\r\n</tr>\r\n</table>${emptyBottomTable}`;\r\n\r\nexport const indexOrderTable = (i) => {\r\n  const date = getDay();\r\n  return `<table border=\"1\"  align=\"center\" >\r\n    <colgroup>\r\n        <col span=\"1\"style=\"\">\r\n      </colgroup>\r\n    <tr align=\"center\" valign=\"center\">\r\n        <td  height=200 width=200  align=\"center\" valign=\"center\"  style=\"color:#fd0004;font-size: 72px;\">${i}</td>\r\n    </tr>\r\n    <tr align=\"center\">\r\n        <td>买家</td>\r\n    </tr>\r\n    <tr align=\"center\">\r\n        <td>购买选项</td>\r\n    </tr>\r\n    <tr align=\"center\">\r\n        <td>客户备注定制</td>\r\n    </tr>\r\n    <tr align=\"center\">\r\n        <td>补丁/规格</td>\r\n    </tr>\r\n    <tr align=\"center\">\r\n        <td>尺寸</td>\r\n    </tr>\r\n    <tr align=\"center\">\r\n        <td>订单号</td>\r\n    </tr>\r\n    <tr align=\"center\">\r\n    <td>订单备注</td>\r\n</tr>\r\n</table>`;\r\n};\r\nexport const orderTable = ({\r\n  textColor,\r\n  img,\r\n  bdAndgg,\r\n  _instruction,\r\n  DZnumber,\r\n  business,\r\n  buyerEmail,\r\n  spec,\r\n  size,\r\n  order_sn,\r\n  orderRemark,\r\n  sBuyColor = \"\", //同个商家颜色\r\n}) => {\r\n  return `<table border=\"1\"  align=\"center\"  bgcolor=\"#e5e9f2\">\r\n        <colgroup>\r\n            <col span=\"1\"style=\"\">\r\n          </colgroup>\r\n        <tr align=\"center\" valign=\"center\">\r\n            <td  height=200 width=200  align=\"center\" valign=\"center\"> <img src=\"https:${img}\" height=\"160\" /></td>\r\n        </tr>\r\n        <tr align=\"center\">\r\n            <td  style=\"background-color:${\r\n              sBuyColor || textColor\r\n            }\">${business}</td>\r\n        </tr>\r\n        <tr align=\"center\">\r\n            <td  >${spec}</td>\r\n        </tr>\r\n         <tr align=\"center\">\r\n            <td style=\"color:green\">${_instruction}</td>\r\n        </tr>\r\n        <tr align=\"center\">\r\n            <td >${bdAndgg}</td>\r\n        </tr>\r\n        <tr align=\"center\">\r\n            <td style=\"color:red\">${size}</td>\r\n        </tr>\r\n        <tr align=\"center\">\r\n            <td style=\"color:${sBuyColor ? textColor : \"blue\"}\">${\r\n    \"&nbsp;\" + order_sn\r\n  }</td>\r\n        </tr>\r\n        <tr align=\"center\">\r\n        <td>${orderRemark}</td>\r\n    </tr>\r\n    </table>`;\r\n};\r\n\r\nexport const simplifyProductName = (str) => {\r\n  return String(str || \"\").replace(\r\n    /Football Shirt?( Kids Size)? 1:1 Thai Quality/g,\r\n    \"\"\r\n  ).trim();\r\n};"],"mappings":"AAAA,SAASA,MAAM,QAAQ,WAAW;AAClC,MAAMC,gBAAgB,GAAG;AACzB;AACA;AACA,aAAa;;AAEb;AACA,OAAO,MAAMC,QAAQ,GAAGA,CAAC;EAAEC,GAAG;EAAEC,OAAO;EAAEC;AAAY,CAAC,KAAK;EACvD,MAAMC,QAAQ,GAAGC,mBAAmB,CAACF,WAAW,CAAC;EACnD,OAAO;AACT;AACA,qFAAqFF,GAAG;AACxF;AACA;AACA,0BAA0BC,OAAO;AACjC;AACA;AACA,0BAA0BE,QAAQ;AAClC;AACA,SAAS;AACT,CAAC;;AAED;AACA,OAAO,MAAME,iBAAiB,GAAG;AACjC;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA,UAAUP,gBAAgB,EAAE;;AAE5B;AACA,OAAO,MAAMQ,cAAc,GAAG;AAC9B;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AA