{"remainingRequest":"/Users/nm/Desktop/zuodan/node_modules/babel-loader/lib/index.js!/Users/nm/Desktop/zuodan/node_modules/cache-loader/dist/cjs.js??ref--1-0!/Users/nm/Desktop/zuodan/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/nm/Desktop/zuodan/src/views/sys6/upload/index.vue?vue&type=script&lang=js","dependencies":[{"path":"/Users/nm/Desktop/zuodan/src/views/sys6/upload/index.vue","mtime":1783534824765},{"path":"/Users/nm/Desktop/zuodan/babel.config.js","mtime":1754447295000},{"path":"/Users/nm/Desktop/zuodan/node_modules/cache-loader/dist/cjs.js","mtime":1783513922041},{"path":"/Users/nm/Desktop/zuodan/node_modules/babel-loader/lib/index.js","mtime":1783513922187},{"path":"/Users/nm/Desktop/zuodan/node_modules/cache-loader/dist/cjs.js","mtime":1783513922041},{"path":"/Users/nm/Desktop/zuodan/node_modules/vue-loader/lib/index.js","mtime":1783513919090}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["_setDataFormat","_restoreDataFormat","_setDataFormatBefore","xlsx","require","__win_data","JSON","parse","window","localStorage","getItem","data","fileList","dataSource","methods","handleRemove","file","onChange","empty","submit","map","item","readerFiles","setTimeout","getFlatDataSource","dataBinary","Promise","resolve","reader","FileReader","readAsBinaryString","raw","onload","ev","target","result","workBook","read","type","cellDates","firstWorkSheet","Sheets","SheetNames","header","getHeaderRow","utils","sheet_to_json","push","sheet","headers","range","decode_range","C","R","s","r","c","e","cell","encode_cell","hdr","t","format_cell","setOneArrFormat","oneDArray","reduce","accumulator","currentValue","concat","length","$message","error","console","log","arrs","isFilterJZCL","enArrs","res","$emit"],"sources":["src/views/sys6/upload/index.vue"],"sourcesContent":["<template>\r\n  <el-card class=\"box-card\">\r\n    <el-upload action=\"#\" :auto-upload=\"false\" :on-change=\"onChange\" :on-remove=\"handleRemove\" :file-list=\"fileList\" multiple\r\n               accept=\".xls,.xlsx\">\r\n      第一步：\r\n      <el-button type=\"primary\">选择文件</el-button>\r\n    </el-upload>\r\n    <div class=\"exp\">\r\n      第二步：\r\n      <el-button type=\"danger\" style=\"width:350px\"\r\n                 @click=\"submit\">（选择文件{{fileList.length || 0}}个）-----导入-----（导入成功{{dataSource.length}}个）</el-button>\r\n    </div>\r\n\r\n  </el-card>\r\n</template>\r\n\r\n<script>\r\nimport { _setDataFormat, _restoreDataFormat, _setDataFormatBefore } from \"./main\";\r\nconst xlsx = require(\"xlsx\");\r\nconst __win_data = JSON.parse(window.localStorage.getItem(\"__sys4-base\")) || {};\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      fileList: [],\r\n      dataSource: [],\r\n    };\r\n  },\r\n  methods: {\r\n    handleRemove(file, fileList) {\r\n      this.fileList = fileList;\r\n    },\r\n    onChange(file, fileList) {\r\n      this.fileList = fileList;\r\n    },\r\n    empty() {\r\n      this.fileList = [];\r\n      this.dataSource = [];\r\n    },\r\n    async submit() {\r\n      this.dataSource = [];\r\n      await this.fileList.map((item) => {\r\n        this.readerFiles(item);\r\n      });\r\n      setTimeout(() => {\r\n        this.getFlatDataSource();\r\n      }, 500);\r\n    },\r\n    async readerFiles(file) {\r\n      /**\r\n       * 1. 使用原生api去读取好的文件\r\n       * */\r\n      // console.log(\"原始上传的文件\", file);\r\n      // 读取文件不是立马能够读取到的，所以是异步的，使用Promise\r\n      let dataBinary = await new Promise((resolve) => {\r\n        // Web API构造函数FileReader，可实例化对象，去调用其身上方法，去读取解析文件信息\r\n        let reader = new FileReader(); // https://developer.mozilla.org/zh-CN/docs/Web/API/FileReader\r\n        // console.log(\"实例化对象有各种方法\", reader);\r\n        reader.readAsBinaryString(file.raw); // 读取raw的File文件\r\n        reader.onload = (ev) => {\r\n          // console.log(\"文件解析流程进度事件\", ev);\r\n          resolve(ev.target.result); // 将解析好的结果扔出去，以供使用\r\n        };\r\n      });\r\n      // console.log(\"读取出的流文件\", dataBinary);\r\n\r\n      /**\r\n       * 2. 使用xlsx插件去解析已经读取好的二进制excel流文件\r\n       * */\r\n      let workBook = xlsx.read(dataBinary, { type: \"binary\", cellDates: true });\r\n      // excel中有很多的sheet，这里取了第一个sheet：workBook.SheetNames[0]\r\n      let firstWorkSheet = workBook.Sheets[workBook.SheetNames[0]];\r\n      // 分为第一行的数据，和第一行下方的数据\r\n      const header = this.getHeaderRow(firstWorkSheet);\r\n      //   console.log(\"读取的excel表头数据（第一行）\", header);\r\n      const data = xlsx.utils.sheet_to_json(firstWorkSheet);\r\n      // console.log(\"读取所有excel数据\", data);\r\n      this.dataSource.push(data);\r\n    },\r\n    getHeaderRow(sheet) {\r\n      const headers = []; // 定义数组，用于存放解析好的数据\r\n      const range = xlsx.utils.decode_range(sheet[\"!ref\"]); // 读取sheet的单元格数据\r\n      let C;\r\n      const R = range.s.r;\r\n      /* start in the first row */\r\n      for (C = range.s.c; C <= range.e.c; ++C) {\r\n        /* walk every column in the range */\r\n        const cell = sheet[xlsx.utils.encode_cell({ c: C, r: R })];\r\n        /* find the cell in the first row */\r\n        let hdr = \"UNKNOWN \" + C; // <-- replace with your desired default\r\n        if (cell && cell.t) hdr = xlsx.utils.format_cell(cell);\r\n        headers.push(hdr);\r\n      }\r\n      return headers; // 经过上方一波操作遍历，得到最终的第一行头数据\r\n    },\r\n    //转成一维数组\r\n    setOneArrFormat() {\r\n      const oneDArray = this.dataSource.reduce((accumulator, currentValue) => {\r\n        return accumulator.concat(currentValue);\r\n      }, []);\r\n      return oneDArray;\r\n    },\r\n    // 把excel的key映射回英文\r\n    getFlatDataSource() {\r\n      if (this.dataSource.length === 0) {\r\n        this.$message.error(\"请先导入数据\");\r\n        return;\r\n      }\r\n      console.log('查看数据元=======', this.dataSource)\r\n      let arrs = this.setOneArrFormat();\r\n      // 转格式之前先看有咩有开启过滤禁止处理的订单\r\n      if(__win_data.isFilterJZCL){\r\n        arrs = _setDataFormatBefore(arrs);\r\n      }\r\n      const enArrs = _setDataFormat(arrs);\r\n      const res = _restoreDataFormat(enArrs);\r\n\r\n      console.log('结果》》》》》',res )\r\n      this.$emit(\"onOk\", res);\r\n\r\n      return res;\r\n    },\r\n  },\r\n};\r\n</script>\r\n<style lang=\"less\" scoped>\r\n.box-card {\r\n  height: 240px;\r\n  overflow-y: auto;\r\n  position: relative;\r\n}\r\n.exp {\r\n  position: absolute;\r\n  bottom: 8px;\r\n  left: 0;\r\n  right: 0px;\r\n  z-index: 20;\r\n}\r\n:deep(.el-upload-list) {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  height: 120px;\r\n  overflow-y: auto;\r\n  border: 1px solid rgba(0, 0, 0, 0.25);\r\n}\r\n:deep(.el-upload-list__item) {\r\n  width: 50%;\r\n}\r\n</style>"],"mappings":";;AAiBA,SAAAA,cAAA,EAAAC,kBAAA,EAAAC,oBAAA;AACA,MAAAC,IAAA,GAAAC,OAAA;AACA,MAAAC,UAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAC,MAAA,CAAAC,YAAA,CAAAC,OAAA;AAEA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,UAAA;IACA;EACA;EACAC,OAAA;IACAC,aAAAC,IAAA,EAAAJ,QAAA;MACA,KAAAA,QAAA,GAAAA,QAAA;IACA;IACAK,SAAAD,IAAA,EAAAJ,QAAA;MACA,KAAAA,QAAA,GAAAA,QAAA;IACA;IACAM,MAAA;MACA,KAAAN,QAAA;MACA,KAAAC,UAAA;IACA;IACA,MAAAM,OAAA;MACA,KAAAN,UAAA;MACA,WAAAD,QAAA,CAAAQ,GAAA,CAAAC,IAAA;QACA,KAAAC,WAAA,CAAAD,IAAA;MACA;MACAE,UAAA;QACA,KAAAC,iBAAA;MACA;IACA;IACA,MAAAF,YAAAN,IAAA;MACA;AACA;AACA;MACA;MACA;MACA,IAAAS,UAAA,aAAAC,OAAA,CAAAC,OAAA;QACA;QACA,IAAAC,MAAA,OAAAC,UAAA;QACA;QACAD,MAAA,CAAAE,kBAAA,CAAAd,IAAA,CAAAe,GAAA;QACAH,MAAA,CAAAI,MAAA,GAAAC,EAAA;UACA;UACAN,OAAA,CAAAM,EAAA,CAAAC,MAAA,CAAAC,MAAA;QACA;MACA;MACA;;MAEA;AACA;AACA;MACA,IAAAC,QAAA,GAAAjC,IAAA,CAAAkC,IAAA,CAAAZ,UAAA;QAAAa,IAAA;QAAAC,SAAA;MAAA;MACA;MACA,IAAAC,cAAA,GAAAJ,QAAA,CAAAK,MAAA,CAAAL,QAAA,CAAAM,UAAA;MACA;MACA,MAAAC,MAAA,QAAAC,YAAA,CAAAJ,cAAA;MACA;MACA,MAAA7B,IAAA,GAAAR,IAAA,CAAA0C,KAAA,CAAAC,aAAA,CAAAN,cAAA;MACA;MACA,KAAA3B,UAAA,CAAAkC,IAAA,CAAApC,IAAA;IACA;IACAiC,aAAAI,KAAA;MACA,MAAAC,OAAA;MACA,MAAAC,KAAA,GAAA/C,IAAA,CAAA0C,KAAA,CAAAM,YAAA,CAAAH,KAAA;MACA,IAAAI,CAAA;MACA,MAAAC,CAAA,GAAAH,KAAA,CAAAI,CAAA,CAAAC,CAAA;MACA;MACA,KAAAH,CAAA,GAAAF,KAAA,CAAAI,CAAA,CAAAE,CAAA,EA