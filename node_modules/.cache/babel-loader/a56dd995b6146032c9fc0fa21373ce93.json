span>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"label\" label=\"中文规格\">\r\n        <template slot-scope=\"scope\">\r\n          <el-input type=\"text\" placeholder=\"请输入中文规格\" v-show=\"scope.row.isEdit\" v-model=\"scope.row.label\">\r\n          </el-input>\r\n          <span v-show=\"!scope.row.isEdit\">{{scope.row.label}}</span>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column fixed=\"right\" label=\"操作\" width=\"150\">\r\n        <template slot-scope=\"scope\">\r\n          <el-button v-if=\"!scope.row.isEdit\" @click=\"edit(scope, true)\" size=\"small\">编辑</el-button>\r\n          <el-button v-else-if=\"scope.row.isEdit\" @click=\"edit(scope, false)\" size=\"small\">完成</el-button>\r\n          <el-button @click=\"del(scope)\" type=\"danger\" size=\"small\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n    <div class=\"add-list\">\r\n      <el-button type=\"info\" icon=\"el-icon-plus\" @click=\"add()\">新增</el-button>\r\n      <el-button style=\"margin-left:20%\" type=\"primary\" @click=\"submit()\">保存</el-button>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nimport { isEmpty } from \"lodash\";\r\nexport default {\r\n  props: [\"data\"],\r\n  watch: {\r\n    data: {\r\n      handler: \"initData\",\r\n      immediate: true,\r\n    },\r\n  },\r\n  data() {\r\n    return {\r\n      tableData: [],\r\n    };\r\n  },\r\n  methods: {\r\n    initData(data) {\r\n      this.tableData = data;\r\n    },\r\n    submit() {\r\n      const _tableData = this.tableData.map((item) => {\r\n        if (isEmpty(item.label) && isEmpty(item.value)) {\r\n          this.$message.error(\"规则信息不能为空!\");\r\n          return;\r\n        }\r\n        return {\r\n          label: item.label.trim(),\r\n          value: item.value.trim(),\r\n        };\r\n      });\r\n      console.log(_tableData, \"--_tableData\");\r\n      this.$emit(\"submit\", _tableData);\r\n    },\r\n    add() {\r\n      this.defaultState();\r\n      this.tableData.push({\r\n        label: \"\",\r\n        value: \"\",\r\n        isEdit: true,\r\n      });\r\n      // 设置滚动条位置\r\n      setTimeout(() => {\r\n        // TODO：暂时写死\r\n        this.$refs.table.bodyWrapper.scrollTop = 9999;\r\n      }, 500);\r\n    },\r\n    edit(item, state) {\r\n      this.defaultState();\r\n      this.$set(this.tableData, item.$index, {\r\n        ...item.row,\r\n        isEdit: state,\r\n      });\r\n    },\r\n    del(item) {\r\n      this.tableData.splice(item.$index, 1);\r\n    },\r\n    // 默认为非编辑状态\r\n    defaultState() {\r\n      this.tableData = this.tableData.map((item) => {\r\n        return {\r\n          ...item,\r\n          isEdit: false,\r\n        };\r\n      });\r\n    },\r\n  },\r\n};\r\n</script>\r\n<style lang=\"less\" scoped>\r\n.add-list {\r\n  display: flex;\r\n  justify-content: center;\r\n  margin-top: 4px;\r\n}\r\n</style>"],"mappings":";AAmCA,SAAAA,OAAA;AACA;EACAC,KAAA;EACAC,KAAA;IACAC,IAAA;MACAC,OAAA;MACAC,SAAA;IACA;EACA;EACAF,KAAA;IACA;MACAG,SAAA;IACA;EACA;EACAC,OAAA;IACAC,SAAAL,IAAA;MACA,KAAAG,SAAA,GAAAH,IAAA;IACA;IACAM,OAAA;MACA,MAAAC,UAAA,QAAAJ,SAAA,CAAAK,GAAA,CAAAC,IAAA;QACA,IAAAZ,OAAA,CAAAY,IAAA,CAAAC,KAAA,KAAAb,OAAA,CAAAY,IAAA,CAAAE,KAAA;UACA,KAAAC,QAAA,CAAAC,KAAA;UACA;QACA;QACA;UACAH,KAAA,EAAAD,IAAA,CAAAC,KAAA,CAAAI,IAAA;UACAH,KAAA,EAAAF,IAAA,CAAAE,KAAA,CAAAG,IAAA;QACA;MACA;MACAC,OAAA,CAAAC,GAAA,CAAAT,UAAA;MACA,KAAAU,KAAA,WAAAV,UAAA;IACA;IACAW,IAAA;MACA,KAAAC,YAAA;MACA,KAAAhB,SAAA,CAAAiB,IAAA;QACAV,KAAA;QACAC,KAAA;QACAU,MAAA;MACA;MACA;MACAC,UAAA;QACA;QACA,KAAAC,KAAA,CAAAC,KAAA,CAAAC,WAAA,CAAAC,SAAA;MACA;IACA;IACAC,KAAAlB,IAAA,EAAAmB,KAAA;MACA,KAAAT,YAAA;MACA,KAAAU,IAAA,MAAA1B,SAAA,EAAAM,IAAA,CAAAqB,MAAA;QACA,GAAArB,IAAA,CAAAsB,GAAA;QACAV,MAAA,EAAAO;MACA;IACA;IACAI,IAAAvB,IAAA;MACA,KAAAN,SAAA,CAAA8B,MAAA,CAAAxB,IAAA,CAAAqB,MAAA;IACA;IACA;IACAX,aAAA;MACA,KAAAhB,SAAA,QAAAA,SAAA,CAAAK,GAAA,CAAAC,IAAA;QACA;UACA,GAAAA,IAAA;UACAY,MAAA;QACA;MACA;IACA;EACA;AACA",