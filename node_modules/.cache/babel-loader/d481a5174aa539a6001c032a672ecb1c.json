{"remainingRequest":"/Users/nm/Desktop/zuodan/node_modules/babel-loader/lib/index.js!/Users/nm/Desktop/zuodan/node_modules/eslint-loader/index.js??ref--14-0!/Users/nm/Desktop/zuodan/src/views/sys6/upload/basicConf.js","dependencies":[{"path":"/Users/nm/Desktop/zuodan/src/views/sys6/upload/basicConf.js","mtime":1783608149759},{"path":"/Users/nm/Desktop/zuodan/babel.config.js","mtime":1754447295000},{"path":"/Users/nm/Desktop/zuodan/node_modules/cache-loader/dist/cjs.js","mtime":1783513922041},{"path":"/Users/nm/Desktop/zuodan/node_modules/babel-loader/lib/index.js","mtime":1783513922187},{"path":"/Users/nm/Desktop/zuodan/node_modules/eslint-loader/index.js","mtime":1783513921405}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["findIndex","_findIndex","__win_data","JSON","parse","window","localStorage","getItem","_patchOpts","patch","_removeSizeSymbol","str","arr","o","indexOf","o1","i","j","k","split","_setColor","res","Math","floor","random","toString","padEnd","extractSpecs","specString","keywords","toCamelCase","toLowerCase","replace","_","chr","toUpperCase","occurrences","kw","patterns","pattern","colonLen","foundIdx","foundPattern","p","idx","spaceCount","length","push","keyword","start","end","sort","a","b","selected","item","overlap","sel","result","cur","next","valueStart","valueEnd","value","substring","trim","pipeIndex","priceSuffixIndex","console","log","_splitChangPingGuiGeOld","replaceAll","positions","resultObj","camelCaseKeywords","map","word","index","charAt","slice","join","forEach","keywordIndex","current","nextIndex","_splitChangPingGuiGe","keywordToCamel","camel","test","escapedKeywords","regex","RegExp","matches","m","exec","lastIndex","startsWith","camelKey","testdata","_setCnPatch","convert","isPathUseEN","inx","label","Array","isArray","every","_setCnSpecification","_setCnModel","_fileToBase64","file","Promise","resolve","reader","FileReader","readAsDataURL","onload","getImageBase64","url","response","fetch","blob"],"sources":["/Users/nm/Desktop/zuodan/src/views/sys6/upload/basicConf.js"],"sourcesContent":["\r\nimport { findIndex as _findIndex } from \"lodash\";\r\n\r\nconst __win_data = JSON.parse(window.localStorage.getItem(\"__sys4-base\"));\r\nconst _patchOpts =  __win_data?.patch;\r\n\r\n//去掉号码的等号啊括号啊那些多余的东西\r\nexport const _removeSizeSymbol = (str) => {\r\n  if (!str) return \"\";\r\n  let arr = [];\r\n  const o = str.indexOf(\":\");\r\n  const o1 = str.indexOf(\"：\");\r\n  const i = str.indexOf(\"=\");\r\n  const j = str.indexOf(\"（\");\r\n  const k = str.indexOf(\"(\");\r\n\r\n  if (o !== -1) {\r\n    arr = str.split(\":\");\r\n  }else if (o1 !== -1) {\r\n    arr = str.split(\"：\");\r\n  }else if (i !== -1) {\r\n    arr = str.split(\"=\");\r\n  } else if (j !== -1) {\r\n    arr = str.split(\"（\");\r\n  } else if (k !== -1) {\r\n    arr = str.split(\"(\");\r\n  } else {\r\n    arr = str.split();\r\n  }\r\n  return arr[1];\r\n};\r\n\r\n//设置随机颜色值\r\nexport const _setColor = () => {\r\n  const res =\r\n    \"#\" +\r\n    Math.floor(Math.random() * 0xffffff)\r\n      .toString(16)\r\n      .padEnd(6, \"0\");\r\n  return res;\r\n};\r\n\r\n\r\nfunction extractSpecs(specString, keywords) {\r\n  if (!specString || typeof specString !== 'string') {\r\n    return {};\r\n  }\r\n\r\n  // 将关键词转换为小写驼峰\r\n  function toCamelCase(str) {\r\n    return str.toLowerCase().replace(/[^a-zA-Z0-9]+(.)/g, (_, chr) => chr.toUpperCase());\r\n  }\r\n\r\n  // 1. 收集每个关键词第一次出现的位置（兼容半角/全角冒号，以及冒号前可能有空格）\r\n  const occurrences = [];\r\n  for (const kw of keywords) {\r\n    // 搜索各种可能的冒号前缀组合\r\n    const patterns = [\r\n      { pattern: kw + ':', colonLen: 1 },     // 无空格 + 半角冒号\r\n      { pattern: kw + ' :', colonLen: 1 },    // 1空格 + 半角冒号\r\n      { pattern: kw + '  :', colonLen: 1 },   // 2空格 + 半角冒号\r\n      { pattern: kw + '：', colonLen: 1 },    // 无空格 + 全角冒号\r\n      { pattern: kw + ' ：', colonLen: 1 },   // 1空格 + 全角冒号\r\n      { pattern: kw + '  ：', colonLen: 1 },  // 2空格 + 全角冒号\r\n    ];\r\n\r\n    let foundIdx = -1;\r\n    let foundPattern = null;\r\n    for (const p of patterns) {\r\n      const idx = specString.indexOf(p.pattern);\r\n      if (idx !== -1 && (foundIdx === -1 || idx < foundIdx)) {\r\n        foundIdx = idx;\r\n        foundPattern = p;\r\n      }\r\n    }\r\n\r\n    if (foundIdx !== -1) {\r\n      // 计算冒号前有多少个空格\r\n      const spaceCount = foundPattern.pattern.length - kw.length - 1; // 去掉关键词和冒号本身的长度\r\n      occurrences.push({\r\n        keyword: kw,\r\n        start: foundIdx,\r\n        end: foundIdx + kw.length + spaceCount + 1  // 跳过关键词 + 空格 + 冒号\r\n      });\r\n    }\r\n  }\r\n\r\n  // 2. 按关键词长度降序，优先保留更长的\r\n  occurrences.sort((a, b) => b.keyword.length - a.keyword.length);\r\n\r\n  // 3. 去除重叠的短关键词\r\n  const selected = [];\r\n  for (const item of occurrences) {\r\n    let overlap = false;\r\n    for (const sel of selected) {\r\n      if (item.start < sel.end && item.end > sel.start) {\r\n        overlap = true;\r\n        break;\r\n      }\r\n    }\r\n    if (!overlap) {\r\n      selected.push(item);\r\n    }\r\n  }\r\n\r\n  // 4. 按起始位置排序\r\n  selected.sort((a, b) => a.start - b.start);\r\n\r\n  // 5. 提取键值对并清洗\r\n  const result = {};\r\n  for (let i = 0; i < selected.length; i++) {\r\n    const cur = selected[i];\r\n    const next = selected[i + 1];\r\n    const valueStart = cur.end;\r\n    const valueEnd = next ? next.start : specString.length;\r\n    let value = specString.substring(valueStart, valueEnd).trim();\r\n\r\n    // 去掉管道符 | 及其后面的内容\r\n    const pipeIndex = value.indexOf('|');\r\n    if (pipeIndex !== -1) {\r\n      value = value.substring(0, pipeIndex).trim();\r\n    }\r\n\r\n    // 去掉 _mimikyu_price_ 及后面的内容（这是嵌入在值里的价格后缀，不是分隔符）\r\n    const priceSuffixIndex = value.indexOf('_mimikyu_price_');\r\n    if (priceSuffixIndex !== -1) {\r\n      value = value.substring(0, priceSuffixIndex).trim();\r\n    }\r\n\r\n    // 如果值为空则赋空字符串\r\n    result[toCamelCase(cur.keyword)] = value || '';\r\n  }\r\n  console.log('查看切割后的数据======', result)\r\n  return result;\r\n}\r\n\r\n// 分切产品规格的数据\r\nexport const _splitChangPingGuiGeOld = (str)=> {\r\n    str = str.replaceAll('Other(Add In The Instruction)','With name and number')\r\n    str = str.replaceAll('Custom ltems','Custom Items')\r\n    str = str.replaceAll('Custom name and number','Custom Items')\r\n    const keywords = [\r\n      'Size',\r\n      'Specification',\r\n      'CUSTOM PATCH',\r\n      'PATCH',\r\n      'Custom Patch',\r\n      'Patch',\r\n      'MODEL',\r\n      'Custom Items',\r\n      'Instruction',\r\n      'Name and Number'\r\n    ];\r\n    const positions = [];\r\n    const resultObj = {};\r\n    // 把关键字转换为驼峰命名\r\n    const camelCaseKeywords = keywords.map(keyword => {\r\n        return keyword\r\n           .toLowerCase()\r\n           .split(' ')\r\n           .map((word, index) => {\r\n                return index === 0? word : word.charAt(0).toUpperCase() + word.slice(1);\r\n            })\r\n           .join('');\r\n    });\r\n\r\n    // 初始化结果对象，将所有驼峰命名的关键字作为属性添加，值初始化为空字符串\r\n    camelCaseKeywords.forEach(keyword => {\r\n        resultObj[keyword] = '';\r\n    });\r\n\r\n    // 记录各个关键字的位置\r\n    keywords.forEach((keyword, index) => {\r\n        const keywordIndex = str.indexOf(keyword);\r\n        if (keywordIndex!== -1) {\r\n            positions.push({ keyword: camelCaseKeywords[index], index: keywordIndex });\r\n        }\r\n    });\r\n\r\n    // 按位置排序\r\n    positions.sort((a, b) => a.index - b.index);\r\n\r\n    for (let i = 0; i < positions.length; i++) {\r\n        const current = positions[i];\r\n        const nextIndex = (i + 1 < positions.length)? positions[i + 1].index : str.length;\r\n        let value = str.slice(current.index + keywords[camelCaseKeywords.indexOf(current.keyword)].length, nextIndex).trim();\r\n        // 去掉冒号\r\n        value = value.replace(':', '');\r\n        resultObj[current.keyword] = value;\r\n    }\r\n    \r\n    return resultObj;\r\n\r\n}\r\n//Size-尺寸， Specification-套装， CUSTOM PATCH-补丁， MODEL-袜子(值就是尺寸)，Custom Items-定制，Instruction-备注\r\nexport const _splitChangPingGuiGe = (str) => {\r\n  console.log('查看字符串======', str)\r\n  // 1. 规范字符串\r\n  str = str.replaceAll('Other(Add In The Instruction)', 'With name and number');\r\n  str = str.replaceAll('Custom ltems', 'Custom Items');\r\n  str = str.replaceAll('Custom name and number', 'Custom Items');\r\n\r\n  const keywords = [\r\n    'Size',\r\n    'Specification',\r\n    'CUSTOM PATCH',\r\n    'PATCH',\r\n    'Custom Patch',\r\n    'Patch',\r\n    'MODEL',\r\n    'Custom Items',\r\n    'Instruction',\r\n    'Name and Number',\r\n    'World Cup Patch',\r\n    'World Cup Patch 2'\r\n  ];\r\n\r\n  const resultObj = {};\r\n  const keywordToCamel = {};\r\n\r\n  // 2. 把关键字转成驼峰，并将所有 Patch 字段统一成 customPatch\r\n  keywords.forEach((keyword) => {\r\n    let camel = keyword\r\n      .toLowerCase()\r\n      .split(' ')\r\n      .map((word, index) =>\r\n        index === 0 ? word : word.charAt(0).toUpperCase() + word.slice(1)\r\n      )\r\n      .join('');\r\n\r\n    // 🔥 所有 PATCH 都归到 customPatch 字段\r\n    if (/patch/i.test(keyword)) {\r\n      camel = 'customPatch';\r\n    }\r\n\r\n    keywordToCamel[keyword] = camel;\r\n\r\n    // 初始化结果对象\r\n    if (!(camel in resultObj)) {\r\n      resultObj[camel] = '';\r\n    }\r\n  });\r\n\r\n  // 3. 构造匹配 “关键字 + 冒号” 的正则\r\n  const escapedKeywords = keywords.map(k =>\r\n    k.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')\r\n  );\r\n  const regex = new RegExp(`(${escapedKeywords.join('|')})\\\\s*:`, 'g');\r\n\r\n  // 4. 找出所有匹配位置\r\n  const matches = [];\r\n  let m;\r\n  while ((m = regex.exec(str)) !== null) {\r\n    matches.push({\r\n      keyword: m[1],\r\n      start: m.index,\r\n      valueStart: regex.lastIndex\r\n    });\r\n  }\r\n\r\n\r\n  // 5. 切片值填入对象\r\n  for (let i = 0; i < matches.length; i++) {\r\n    const current = matches[i];\r\n    const next = matches[i + 1];\r\n    const end = next ? next.start : str.length;\r\n\r\n    let value = str.slice(current.valueStart, end).trim();\r\n    if (value.startsWith(':')) value = value.slice(1).trim();\r\n\r\n    const camelKey = keywordToCamel[current.keyword];\r\n    resultObj[camelKey] = value;\r\n  }\r\n\r\n  const testdata = extractSpecs(str, keywords)\r\n  console.log('格式化函数输出======', keywords, testdata, resultObj)\r\n\r\n  return testdata;\r\n  // return resultObj;\r\n\r\n}\r\n\r\n\r\n// 配置中文的补丁\r\n// export const _setCnPatch = (str)=>{\r\n//   if(!str || str ==='NO' || str ==='No' || str ==='no') return ''\r\n//   if(__win_data.isPathUseEN){\r\n//     let res = ''\r\n//     const inx = _findIndex(_patchOpts,['value',str])\r\n//     if(inx === -1){\r\n//       res = str\r\n//     }else{\r\n//       res = _patchOpts[inx].label\r\n//     }\r\n//     return res\r\n//   }\r\n//   return str\r\n// }\r\nexport const _setCnPatch = (str) => {\r\n  if (!str) return '';\r\n\r\n  const convert = (item) => {\r\n    if (!item || item === 'NO' || item === 'No' || item === 'no') {\r\n      return '';\r\n    }\r\n\r\n    if (__win_data.isPathUseEN) {\r\n      const inx = _findIndex(_patchOpts, ['value', item]);\r\n      return inx === -1 ? item : _patchOpts[inx].label;\r\n    }\r\n\r\n    return item;\r\n  };\r\n\r\n  if (Array.isArray(str)) {\r\n    const res = str.map(convert);\r\n    // 如果所有项都为空，则返回 null\r\n    return res.every(item => item === '') ? null : res;\r\n  }\r\n\r\n  return convert(str);\r\n};\r\n\r\n// 配置中文的套装\r\nexport const _setCnSpecification = (str)=>{\r\n  if(str === 'Suit' || str === 'suit'){\r\n    return '套装'\r\n  }\r\n  if(str === 'Jacket' || str === 'jacket'){\r\n    return '上衣'\r\n  }\r\n  if(str === 'Shorts' || str === 'shorts'){\r\n    return '裤子'\r\n  }\r\n  return str\r\n}\r\n\r\n// 配置中文的袜子\r\nexport const _setCnModel = (str)=>{\r\n  if(str === 'Adult' || str === 'adult'){\r\n    return '大人'\r\n  }\r\n  if(str === 'Kids' || str === 'kids'){\r\n    return '小孩'\r\n  }\r\n  return str\r\n}\r\n\r\n// 图片转成base64\r\nexport const _fileToBase64 = (file) => {\r\n