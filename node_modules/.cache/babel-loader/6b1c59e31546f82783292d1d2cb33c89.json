{"remainingRequest":"/Users/nm/Desktop/zuodan-plus 源码/node_modules/babel-loader/lib/index.js!/Users/nm/Desktop/zuodan-plus 源码/node_modules/cache-loader/dist/cjs.js??ref--1-0!/Users/nm/Desktop/zuodan-plus 源码/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/nm/Desktop/zuodan-plus 源码/src/views/Main.vue?vue&type=script&lang=js","dependencies":[{"path":"/Users/nm/Desktop/zuodan-plus 源码/src/views/Main.vue","mtime":1774108233000},{"path":"/Users/nm/Desktop/zuodan-plus 源码/babel.config.js","mtime":1754447295000},{"path":"/Users/nm/Desktop/zuodan-plus 源码/node_modules/cache-loader/dist/cjs.js","mtime":1783513922041},{"path":"/Users/nm/Desktop/zuodan-plus 源码/node_modules/babel-loader/lib/index.js","mtime":1783513922187},{"path":"/Users/nm/Desktop/zuodan-plus 源码/node_modules/cache-loader/dist/cjs.js","mtime":1783513922041},{"path":"/Users/nm/Desktop/zuodan-plus 源码/node_modules/vue-loader/lib/index.js","mtime":1783513919090}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["Empty","downBtn2","downBtn1","downBtn","startSort","cloneDeep","_cloneDeep","startSetExcelDate","getDay","saveAs","Box","getSnText","name","components","data","orderArrsDatas","orderAllNum","goodsAllNum","fileName","allIndex","allExportDatas","specExportData","imgExportData","timer","dataScreen","exportData","fields","lastOrderNum","isOrderPage","boxVisible","beforeMount","$route","query","type","mounted","initDataScreenFields","methods","save","group","datas","arrs","setExcelTable","window","__shop_save_datas","dataSource","JSON","parse","stringify","goodsNums","orderNums","key","length","res","arrDatas","defineIndex","tableArrs","console","log","goodsImgNum","$message","message","showClose","duration","offset","createExportDataScreen","spec","obj","dataScreenFields","订单总条数","衣服总件数","最后一条订单单号","map","item","value","id","$set","scrollTop","document","documentElement","body","scrollHeight","exportOrder","allOrder_sn","str","Blob","handleBox"],"sources":["src/views/Main.vue"],"sourcesContent":["<template>\r\n  <div class=\"home\">\r\n    <div class=\"box\">\r\n      <div class=\"btns-main\">\r\n        <span class=\"margin-ri\">订单总条数：{{ orderAllNum }};</span>\r\n        <span class=\"margin-ri\">衣服总件数：{{ goodsAllNum }}</span>\r\n      </div>\r\n      <div class=\"btns\">\r\n        <span v-for=\"(item, i) in downBtn\" :key=\"item.key\" class=\"btns-item\">\r\n          <span class=\"num margin-bot-4\">订单个数：{{ (orderArrsDatas && orderArrsDatas[item.id]?.length) || 0 }}</span>\r\n          <!-- <div class=\"margin-bot-4\">\r\n            <el-button size=\"small\" type=\"info\">单号</el-button>\r\n          </div> -->\r\n          <span class=\"mar-bot\">\r\n            <download-excel :ref=\"`download-img${i}`\" :class=\"['export-img']\" :data=\"imgExportData[item.id] || []\"\r\n                            :name=\"fileName + '图片-' + item.value + timer + '.xls'\">img</download-excel>\r\n          </span>\r\n\r\n          <span class=\"margin-bot-4\">\r\n            <download-excel :ref=\"`download${i}`\" :class=\"['export', item.class]\" :data=\"specExportData[item.id] || []\"\r\n                            :name=\"fileName + item.value + '-' + timer + '.xls'\">\r\n              {{ item.value }}\r\n            </download-excel>\r\n          </span>\r\n\r\n          <!-- <span class=\"num\">商品个数：{{ (allExportDatas && allExportDatas[item.id]?.goodsImgNum) || 0 }}</span> -->\r\n          <div class=\"mar-bot0\">\r\n            <el-input size=\"small\" style=\"width: 80px\" v-model=\"allIndex[item.id]\" placeholder=\"开始索引,默认1\"></el-input>\r\n          </div>\r\n        </span>\r\n      </div>\r\n\r\n      <!-- 静态 -->\r\n      <p class=\"box-info\">\r\n        <span class=\"zonglan\">\r\n          <el-button type=\"info\" @click=\"exportOrder\">全部单号汇总</el-button>\r\n          <el-button class=\"all-btn\" type=\"success\" @click=\"handleBox\">条件汇总</el-button>\r\n          <!-- <download-excel :ref=\"`downloadAll`\" class=\"export color-67c23a\" :fields=\"dataScreen.fields\" :data=\"dataScreen.exportData\" :name=\"'总览' + fileName + '-' + timer + '.xls'\">\r\n            总览数据\r\n          </download-excel> -->\r\n        </span>\r\n\r\n        <span>\r\n          <span class=\"api-text\">name：</span>\r\n          <span class=\"input-span\">\r\n            <el-input size=\"small\" v-model=\"fileName\" placeholder=\"请输入文件名\"></el-input>\r\n          </span>\r\n        </span>\r\n\r\n        <router-link v-if=\"!isOrderPage\" to=\"order?type=2\" target=\"_blank\">旧版规格</router-link>\r\n        <router-link v-if=\"!isOrderPage\" to=\"order?type=1\" target=\"_blank\">其他店</router-link>\r\n      </p>\r\n    </div>\r\n\r\n    <!-- 录入 -->\r\n    <div class=\"form\">\r\n      <Empty ref=\"empty\" @save=\"save\" @scrollTop=\"scrollTop\" />\r\n    </div>\r\n\r\n    <!-- 弹窗 -->\r\n    <Box :dialogVisible=\"boxVisible\" @onOk=\"boxVisible = false\" @onCancel=\"boxVisible = false\" />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Empty from \"./Empty.vue\";\r\nimport { downBtn2, downBtn1, downBtn } from \"../utils/enum\";\r\nimport { startSort } from \"../utils/baseDataSort\";\r\nimport { cloneDeep as _cloneDeep } from \"lodash\";\r\nimport { startSetExcelDate } from \"../utils/main2\";\r\nimport { getDay } from \"../utils/base\";\r\nimport { saveAs } from \"file-saver\";\r\nimport Box from \"./Box.vue\";\r\nimport { getSnText } from \"../utils/ordersnExport\";\r\n\r\nexport default {\r\n  name: \"Main\",\r\n  components: {\r\n    Empty,\r\n    Box,\r\n  },\r\n  data: () => {\r\n    return {\r\n      orderArrsDatas: {}, //遍历好的数据\r\n      orderAllNum: 0, //\r\n      goodsAllNum: 0, //\r\n      fileName: \"\", //文件名\r\n      allIndex: {},\r\n      allExportDatas: {}, //所有导出数据\r\n      specExportData: {}, //规格导出数据\r\n      imgExportData: {}, //excel的图片汇总\r\n      downBtn: [],\r\n      timer: \"\",\r\n      // json_fields: {},\r\n      // json_data: [],\r\n      // json_meta: [\r\n      //   [\r\n      //     {\r\n      //       key: 'charset',\r\n      //       value: 'utf-8',\r\n      //     },\r\n      //   ],\r\n      // ],\r\n      //数据总览\r\n      dataScreen: {\r\n        exportData: [],\r\n        fields: {},\r\n      },\r\n      lastOrderNum: \"\",\r\n      isOrderPage: null,\r\n      boxVisible: false,\r\n    };\r\n  },\r\n  beforeMount() {\r\n    this.downBtn = [];\r\n    if (this.$route.query && this.$route.query.type == 1) {\r\n      this.isOrderPage = true;\r\n      this.downBtn = downBtn1;\r\n    } else if (this.$route.query && this.$route.query.type == 2) {\r\n      this.isOrderPage = true;\r\n      this.downBtn = downBtn2;\r\n    } else {\r\n      this.isOrderPage = false;\r\n      this.downBtn = downBtn;\r\n    }\r\n  },\r\n  mounted() {\r\n    this.initDataScreenFields();\r\n  },\r\n  methods: {\r\n    //保存提交转化数据\r\n    save({ data, lastOrderNum }) {\r\n      this.lastOrderNum = lastOrderNum;\r\n      const { group } = data;\r\n      const datas = startSort({ arrs: group });\r\n      //copy一份数据\r\n      this.orderArrsDatas = _cloneDeep(datas);\r\n      // 设置table格式\r\n      this.setExcelTable(datas);\r\n      this.timer = getDay();\r\n\r\n      //在全局挂一份数据给其他地方用\r\n      window.__shop_save_datas = {\r\n        ...window.__shop_save_datas,\r\n        fileName: this.fileName,\r\n        timer: this.timer,\r\n        dataSource: JSON.parse(JSON.stringify({ ...this.orderArrsDatas })),\r\n      };\r\n    },\r\n    //设置excel表的table格式\r\n    setExcelTable(datas) {\r\n      let goodsNums = 0;\r\n      let orderNums = 0;\r\n      //转excel\r\n      this.specExportData = datas;\r\n      for (const key in datas) {\r\n        orderNums = orderNums + datas[key].length;\r\n        if (datas[key].length > 0) {\r\n          const res = startSetExcelDate({\r\n            arrDatas: datas[key],\r\n            key,\r\n            defineIndex: this.allIndex[key],\r\n          });\r\n\r\n          this.specExportData[key] = res.tableArrs;\r\n          console.log(res, \"====imgExportData\");\r\n          this.imgExportData[key] = res.imgExportData;\r\n\r\n          this.allExportDatas[key] = res;\r\n          goodsNums = goodsNums + res.goodsImgNum;\r\n        }\r\n      }\r\n      this.goodsAllNum = goodsNums;\r\n      this.orderAllNum = orderNums;\r\n      this.$message({\r\n        message: \"数据转化成功，快去下载\",\r\n        showClose: true,\r\n        type: \"success\",\r\n        duration: 800,\r\n        offset: 10,\r\n      });\r\n      //结果\r\n      //创建总览导出数据\r\n      this.createExportDataScreen();\r\n    },\r\n    // 总览单独处理导出\r\n    createExportDataScreen() {\r\n      //规格的\r\n      const spec = {};\r\n      for (const key in this.allExportDatas) {\r\n        //订单总数+商品总数\r\n        spec[key] =\r\n          \"订单数\" +\r\n          this.orderArrsDatas[key].length +\r\n          \" / \" +\r\n          \"结束索引\" +\r\n          (this.allExportDatas[key].defineIndex - 1);\r\n      }\r\n\r\n      const obj = {\r\n        orderAllNum: this.orderAllNum,\r\n        goodsAllNum: this.goodsAllNum,\r\n        lastOrderNum: this.lastOrderNum,\r\n        fileName: this.fileName + \"xx\" + this.timer,\r\n        //规格的\r\n        ...spec,\r\n      };\r\n      this.dataScreen.exportData = [obj];\r\n    },\r\n    initDataScreenFields() {\r\n      const dataScreenFields = {\r\n        订单总条数: \"orderAllNum\",\r\n        衣服总件数: \"goodsAllNum\",\r\n        最后一条订单单号: \"lastOrderNum\",\r\n      };\r\n      //注入规格\r\n      this.downBtn.map((item) => {\r\n        dataScreenFields[item.value] = item.id;\r\n        this.$set(this.allIndex, [item.id], 1);\r\n      });\r\n\r\n      this.dataScreen.fields = dataScreenFields;\r\n    },\r\n    scrollTop() {\r\n      document.documentElement.scrollTop = document.body.scrollHeight;\r\n    },\r\n    exportOrder() {\r\n      const { allOrder_sn } = window.__shop_save_datas || {};\r\n      if (allOrder_sn) {\r\n        const str = getSnText(allOrder_sn);\r\n        const res = new Blob([str], { type: \"text/plain;charset=utf-8\" });\r\n        const name = `${this.fileName || \"\"}汇总全部单号-${this.timer}.txt`;\r\n        saveAs(res, `${name}`);\r\n        this.$message({\r\n          message: \"单号汇总，下载成功～\",\r\n          showClose: true,\r\n          type: \"success\",\r\n          duration: 800,\r\n          offset: 10,\r\n        });\r\n      } else {\r\n        this.$message({\r\n          message: \"请先转化数据\",\r\n          showClose: true,\r\n          type: \"error\",\r\n          duration: 800,\r\n          offset: 10,\r\n        });\r\n      }\r\n    },\r\n    handleBox() {\r\n      this.boxVisible = true;\r\n    },\r\n  },\r\n};\r\n</script>\r\n<style lang=\"less\" scoped>\r\n.home {\r\n  font-size: 14px;\r\n}\r\n.box {\r\n  top: 60px;\r\n  padding-top: 10px;\r\n  position: fixed;\r\n  width: 100%;\r\n  z-index: 101;\r\n  box-sizing: border-box;\r\n  background-color: #e5e9f2;\r\n  height: 294px;\r\n}\r\n\r\n.btns {\r\n  display: flex;\r\n  justify-content: space-around;\r\n  &-item {\r\n    border: 1px solid #409eff;\r\n    padding: 2px;\r\n    border-radius: 4px;\r\n  }\r\n}\r\n.export {\r\n  border-radius: 4px;\r\n  font-size: 14px;\r\n  padding: 2px 8px;\r\n  cursor: pointer;\r\n  color: #fff;\r\n  background-color: #409eff;\r\n  border-color: #67c23a;\r\n  height: 40px;\r\n  line-height: 40px;\r\n  text-align: center;\r\n}\r\n.form {\r\n  padding-top: 290px;\r\n}\r\n.num {\r\n  font-size: 12px;\r\n  display: block;\r\n}\r\n.margin-bot-4 {\r\n  margin-bottom: 4px;\r\n}\r\n.input-index {\r\n  display: inline-block;\r\n  width: 100px;\r\n}\r\n.input-span {\r\n  width: 200px;\r\n  display: inline-block;\r\n}\r\n\r\n.btns-main {\r\n  font-weight: bolder;\r\n  font-size: 24px;\r\n}\r\n.margin-ri {\r\n  margin-right: 30px;\r\n}\r\n.api-text {\r\n  color: black;\r\n  font-weight: bolder;\r\n  font-size: 16px;\r\n}\r\n.step {\r\n  font-size: 26px;\r\n  color: red;\r\n}\r\n\r\n.zonglan {\r\n  display: flex;\r\n}\r\n.color-67c23a {\r\n  border-color: #67c23a;\r\n  background-color: #67c23a;\r\n}\r\n.box-info {\r\n  display: flex;\r\n  padding-left: 10px;\r\n  padding-right: 10px;\r\n  justify-content: space-around;\r\n  align-items: center;\r\n  margin-top: 30px;\r\n  & > span {\r\n    display: inline-block;\r\n  }\r\n}\r\n.mar-bot {\r\n  margin-bottom: 6px;\r\n  display: block;\r\n}\r\n.mar-bot0 {\r\n  margin-top: 6px;\r\n}\r\n\r\n//图片下载\r\n.export-img {\r\n  width: 60px;\r\n  border-radius: 4px;\r\n  font-size: 14px;\r\n  padding: 2px 8px;\r\n  cursor: pointer;\r\n  color: #000;\r\n  background-color: #e6a23c;\r\n  height: 30px;\r\n  line-height: 30px;\r\n  text-align: center;\r\n  margin: auto;\r\n  // border: 1px solid #67c23a;\r\n}\r\n:deep(.el-form-item__label) {\r\n  font-weight: bolder;\r\n}\r\n\r\n.export-extra {\r\n  background-color: #ee4d2d;\r\n}\r\n.all-btn {\r\n  height: 44px;\r\n  width: 150px;\r\n}\r\n</style>\r\n"],"mappings":"AAiEA,OAAAA,KAAA;AACA,SAAAC,QAAA,EAAAC,QAAA,EAAAC,OAAA;AACA,SAAAC,SAAA;AACA,SAAAC,SAAA,IAAAC,UAAA;AACA,SAAAC,iBAAA;AACA,SAAAC,MAAA;AACA,SAAAC,MAAA;AACA,OAAAC,GAAA;AACA,SAAAC,SAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAb,KAAA;IACAU;EACA;EACAI,IAAA,EAAAA,CAAA;IACA;MACAC,cAAA;MAAA;MACAC,WAAA;MAAA;MACAC,WAAA;MAAA;MACAC,QAAA;MAAA;MACAC,QAAA;MACAC,cAAA;MAAA;MACAC,cAAA;MAAA;MACAC,aAAA;MAAA;MACAnB,OAAA;MACAoB,KAAA;MACA;MACA;MACA;MACA;MACA;MACA;MACA;MACA;MACA;MACA;MACA;MACAC,UAAA;QACAC,UAAA;QACAC,MAAA;MACA;MACAC,YAAA;MACAC,WAAA;MACAC,UAAA;IACA;EACA;EACAC,YAAA;IACA,KAAA3B,OAAA;IACA,SAAA4B,MAAA,CAAAC,KAAA,SAAAD,MAAA,CAAAC,KAAA,CAAAC,IAAA;MACA,KAAAL,WAAA;MACA,KAAAzB,OAAA,GAAAD,QAAA;IACA,gBAAA6B,MAAA,CAAAC,KAAA,SAAAD,MAAA,CAAAC,KAAA,CAAAC,IAAA;MACA,KAAAL,WAAA;MACA,KAAAzB,OAAA,GAAAF,QAAA;IACA;MACA,KAAA2B,WAAA;MACA,KAAAzB,OAAA,GAAAA,OAAA;IACA;EACA;EACA+B,QAAA;IACA,KAAAC,oBAAA;EACA;EACAC,OAAA;IACA;IACAC,KAAA;MAAAvB,IAAA;MAAAa;IAAA;MACA,KAAAA,YAAA,GAAAA,YAAA;MACA;QAAAW;MAAA,IAAAxB,IAAA;MACA,MAAAyB,KAAA,GAAAnC,SAAA;QAAAoC,IAAA,EAAAF;MAAA;MACA;MACA,KAAAvB,cAAA,GAAAT,UAAA,CAAAiC,KAAA;MACA;MACA,KAAAE,aAAA,CAAAF,KAAA;MACA,KAAAhB,