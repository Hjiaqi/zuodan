{"remainingRequest":"/Users/nm/Desktop/zuodan/node_modules/babel-loader/lib/index.js!/Users/nm/Desktop/zuodan/node_modules/eslint-loader/index.js??ref--14-0!/Users/nm/Desktop/zuodan/src/utils/base.js","dependencies":[{"path":"/Users/nm/Desktop/zuodan/src/utils/base.js","mtime":1774108233000},{"path":"/Users/nm/Desktop/zuodan/babel.config.js","mtime":1754447295000},{"path":"/Users/nm/Desktop/zuodan/node_modules/cache-loader/dist/cjs.js","mtime":1783513922041},{"path":"/Users/nm/Desktop/zuodan/node_modules/babel-loader/lib/index.js","mtime":1783513922187},{"path":"/Users/nm/Desktop/zuodan/node_modules/eslint-loader/index.js","mtime":1783513921405}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["SPEC2","SPEC1","SPEC","window_href","HREF","window","location","href","PAGE_TYPE1","indexOf","PAGE_TYPE2","curPage","which_spec","getDay","d","Date","time","getMonth","getDate","getHours","getMinutes","getDay2","m","mm","getFullYear","setKeys","arr","key","res","map","item","push","set_color","Math","floor","random","toString","padEnd","getItem_img","str","getItem_time","obj","getItem_size","split","getItem_spec_size","item_model","name","o","spec","length","size","getSku_spec_size","getSize","i","j","k"],"sources":["/Users/nm/Desktop/zuodan/src/utils/base.js"],"sourcesContent":["import { SPEC2, SPEC1, SPEC } from './enum'\r\n\r\n//获取window信息\r\nexport const window_href = () => {\r\n  const HREF = window.location.href\r\n  const PAGE_TYPE1 = HREF.indexOf('type=1')\r\n  const PAGE_TYPE2 = HREF.indexOf('type=2')\r\n  let curPage = ''//order-ning店；old-旧店；new-新排序\r\n  let which_spec = []\r\n  if (PAGE_TYPE1 > 0) {\r\n    which_spec = SPEC1\r\n    curPage = 'order'\r\n  } else if (PAGE_TYPE2 > 0) {\r\n    which_spec = SPEC2\r\n    curPage = 'old'\r\n  } else {\r\n    which_spec = SPEC\r\n    curPage = 'new'\r\n  }\r\n  return {\r\n    which_spec,\r\n    curPage\r\n  }\r\n}\r\n\r\n//获取年月日时分秒\r\nexport const getDay = () => {\r\n  const d = new Date();\r\n  // d.getFullYear() + \"-\" ++ \":\" + d.getSeconds()\r\n  let time = (d.getMonth() + 1) + \"月\" + d.getDate() + \"日\" + d.getHours() + \"时\" + d.getMinutes() + \"分\";\r\n\r\n  return time\r\n}\r\n\r\n//获取年月日时分秒\r\nexport const getDay2 = () => {\r\n  const d = new Date();\r\n  const m = d.getMonth() + 1\r\n  const mm = m < 10 ? '0' + m : m\r\n  let time =d.getFullYear() + '-' + mm + \"-\" + d.getDate();\r\n\r\n  return time\r\n}\r\n\r\n// //获取某个keys\r\n// export const setKeys = (arr, key) => {\r\n//   return arr.map(item => {\r\n//     return item[key]\r\n//   })\r\n// }\r\n\r\n//获取某个keys\r\nexport const setKeys = (arr, key) => {\r\n  const res = []\r\n   arr.map(item => {\r\n    if(item[key]){\r\n      res.push(item[key]) \r\n    }\r\n  })\r\n  return res\r\n}\r\n\r\n\r\n//设置随机颜色值\r\nexport const set_color = () => {\r\n  const res = \"#\" + Math.floor(Math.random() * 0xffffff).toString(16).padEnd(6, \"0\")\r\n  return res\r\n}\r\n\r\n//图片\r\nexport const getItem_img = (str) => {\r\n  return `https://s-cf-br.shopeesz.com/file/${str}_tn`\r\n}\r\n\r\n//获取时间\r\nexport const getItem_time = (obj) => {\r\n  return ''\r\n}\r\n\r\n//获取尺寸\r\nexport const getItem_size = (str) => {\r\n  const arr = str.split('=')\r\n  return arr[0]\r\n}\r\n\r\n//获取规格\r\nexport const getItem_spec_size = (obj) => {\r\n  const str = obj.item_model.name\r\n  const arr = str.split(',')\r\n  const o = {\r\n    spec: arr[0],\r\n  }\r\n  if (arr.length > 1) {\r\n    o.size = arr[1]\r\n  }\r\n  return o\r\n}\r\n\r\n\r\n//获取sku 一个商品多规格\r\nexport const getSku_spec_size = (name) => {\r\n  const arr = name.split(',')\r\n  const o = {\r\n    spec: arr[0],\r\n  }\r\n  if (arr.length > 1) {\r\n    o.size = arr[1]\r\n  }\r\n  return o\r\n}\r\n\r\n\r\n//获取尺寸\r\nexport const getSize = (str) => {\r\n  if (!str) return '没码数'\r\n  // return str\r\n  let arr = []\r\n  const i = str.indexOf('=')\r\n  const j = str.indexOf('（')\r\n  const k = str.indexOf('(')\r\n\r\n  if (i !== -1) {\r\n    arr = str.split('=')\r\n  } else if (j !== -1) {\r\n    arr = str.split('（')\r\n  } else if (k !== -1) {\r\n    arr = str.split('(')\r\n  } else {\r\n    arr = str.split()\r\n  }\r\n  return arr[0]\r\n}\r\n"],"mappings":";AAAA,SAASA,KAAK,EAAEC,KAAK,EAAEC,IAAI,QAAQ,QAAQ;;AAE3C;AACA,OAAO,MAAMC,WAAW,GAAGA,CAAA,KAAM;EAC/B,MAAMC,IAAI,GAAGC,MAAM,CAACC,QAAQ,CAACC,IAAI;EACjC,MAAMC,UAAU,GAAGJ,IAAI,CAACK,OAAO,CAAC,QAAQ,CAAC;EACzC,MAAMC,UAAU,GAAGN,IAAI,CAACK,OAAO,CAAC,QAAQ,CAAC;EACzC,IAAIE,OAAO,GAAG,EAAE;EAChB,IAAIC,UAAU,GAAG,EAAE;EACnB,IAAIJ,UAAU,GAAG,CAAC,EAAE;IAClBI,UAAU,GAAGX,KAAK;IAClBU,OAAO,GAAG,OAAO;EACnB,CAAC,MAAM,IAAID,UAAU,GAAG,CAAC,EAAE;IACzBE,UAAU,GAAGZ,KAAK;IAClBW,OAAO,GAAG,KAAK;EACjB,CAAC,MAAM;IACLC,UAAU,GAAGV,IAAI;IACjBS,OAAO,GAAG,KAAK;EACjB;EACA,OAAO;IACLC,UAAU;IACVD;EACF,CAAC;AACH,CAAC;;AAED;AACA,OAAO,MAAME,MAAM,GAAGA,CAAA,KAAM;EAC1B,MAAMC,CAAC,GAAG,IAAIC,IAAI,CAAC,CAAC;EACpB;EACA,IAAIC,IAAI,GAAIF,CAAC,CAACG,QAAQ,CAAC,CAAC,GAAG,CAAC,GAAI,GAAG,GAAGH,CAAC,CAACI,OAAO,CAAC,CAAC,GAAG,GAAG,GAAGJ,CAAC,CAACK,QAAQ,CAAC,CAAC,GAAG,GAAG,GAAGL,CAAC,CAACM,UAAU,CAAC,CAAC,GAAG,GAAG;EAEnG,OAAOJ,IAAI;AACb,CAAC;;AAED;AACA,OAAO,MAAMK,OAAO,GAAGA,CAAA,KAAM;EAC3B,MAAMP,CAAC,GAAG,IAAIC,IAAI,CAAC,CAAC;EACpB,MAAMO,CAAC,GAAGR,CAAC,CAACG,QAAQ,CAAC,CAAC,GAAG,CAAC;EAC1B,MAAMM,EAAE,GAAGD,CAAC,GAAG,EAAE,GAAG,GAAG,GAAGA,CAAC,GAAGA,CAAC;EAC/B,IAAIN,IAAI,GAAEF,CAAC,CAACU,WAAW,CAAC,CAAC,GAAG,GAAG,GAAGD,EAAE,GAAG,GAAG,GAAGT,CAAC,CAACI,OAAO,CAAC,CAAC;EAExD,OAAOF,IAAI;AACb,CAAC;;AAED;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA,OAAO,MAAMS,OAAO,GAAGA,CAACC,GAAG,EAAEC,GAAG,KAAK;EACnC,MAAMC,GAAG,GAAG,EAAE;EACbF,GAAG,CAACG,GAAG,CAACC,IAAI,IAAI;IACf,IAAGA,IAAI,CAACH,GAAG,CAAC,EAAC;MACXC,GAAG,CAACG,IAAI,CAACD,IAAI,CAACH,GAAG,CAAC,CAAC;IACrB;EACF,CAAC,CAAC;EACF,OAAOC,GAAG;AACZ,CAAC;;AAGD;AACA,OAAO,MAAMI,SAAS,GAAGA,CAAA,KAAM;EAC7B,MAAMJ,GAAG,GAAG,GAAG,GAAGK,IAAI,CAACC,KAAK,CAACD,IAAI,CAACE,MAAM,CAAC,CAAC,GAAG,QAAQ,CAAC,CAACC,QAAQ,CAAC,EAAE,CAAC,CAACC,MAAM,CAAC,CAAC,EAAE,GAAG,CAAC;EAClF,OAAOT,GAAG;AACZ,CAAC;;AAED;AACA,OAAO,MA