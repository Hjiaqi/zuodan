{"remainingRequest":"/Users/nm/Desktop/zuodan/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/nm/Desktop/zuodan/src/views/sys6/config/SpecTable.vue?vue&type=style&index=0&id=3b39fcc2&lang=less&scoped=true","dependencies":[{"path":"/Users/nm/Desktop/zuodan/src/views/sys6/config/SpecTable.vue","mtime":1774108233000},{"path":"/Users/nm/Desktop/zuodan/node_modules/css-loader/dist/cjs.js","mtime":1783513921726},{"path":"/Users/nm/Desktop/zuodan/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":1783513919095},{"path":"/Users/nm/Desktop/zuodan/node_modules/postcss-loader/src/index.js","mtime":1783513920062},{"path":"/Users/nm/Desktop/zuodan/node_modules/less-loader/dist/cjs.js","mtime":1783513920586},{"path":"/Users/nm/Desktop/zuodan/node_modules/cache-loader/dist/cjs.js","mtime":1783513922041},{"path":"/Users/nm/Desktop/zuodan/node_modules/vue-loader/lib/index.js","mtime":1783513919090}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:DQouYWRkLWxpc3Qgew0KICBkaXNwbGF5OiBmbGV4Ow0KICBqdXN0aWZ5LWNvbnRlbnQ6IGNlbnRlcjsNCiAgbWFyZ2luLXRvcDogNHB4Ow0KfQ0K"},{"version":3,"sources":["SpecTable.vue"],"names":[],"mappings":";AAuGA;AACA;AACA;AACA;AACA","file":"SpecTable.vue","sourceRoot":"src/views/sys6/config","sourcesContent":["\r\n<template>\r\n  <div>\r\n    <el-table ref=\"table\" :data=\"tableData\" border height=\"400\" style=\"width: 100%\">\r\n      <el-table-column type=\"index\" label=\"序号\" width=\"50\">\r\n      </el-table-column>\r\n      <el-table-column prop=\"value\" label=\"英文规格\">\r\n        <template slot-scope=\"scope\">\r\n          <el-input type=\"text\" placeholder=\"请输入英文规格\" v-show=\"scope.row.isEdit\" v-model=\"scope.row.value\">\r\n          </el-input>\r\n          <span v-show=\"!scope.row.isEdit\">{{scope.row.value}}</span>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"label\" label=\"中文规格\">\r\n        <template slot-scope=\"scope\">\r\n          <el-input type=\"text\" placeholder=\"请输入中文规格\" v-show=\"scope.row.isEdit\" v-model=\"scope.row.label\">\r\n          </el-input>\r\n          <span v-show=\"!scope.row.isEdit\">{{scope.row.label}}</span>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column fixed=\"right\" label=\"操作\" width=\"150\">\r\n        <template slot-scope=\"scope\">\r\n          <el-button v-if=\"!scope.row.isEdit\" @click=\"edit(scope, true)\" size=\"small\">编辑</el-button>\r\n          <el-button v-else-if=\"scope.row.isEdit\" @click=\"edit(scope, false)\" size=\"small\">完成</el-button>\r\n          <el-button @click=\"del(scope)\" type=\"danger\" size=\"small\">删除</el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n    <div class=\"add-list\">\r\n      <el-button type=\"info\" icon=\"el-icon-plus\" @click=\"add()\">新增</el-button>\r\n      <el-button style=\"margin-left:20%\" type=\"primary\" @click=\"submit()\">保存</el-button>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nimport { isEmpty } from \"lodash\";\r\nexport default {\r\n  props: [\"data\"],\r\n  watch: {\r\n    data: {\r\n      handler: \"initData\",\r\n      immediate: true,\r\n    },\r\n  },\r\n  data() {\r\n    return {\r\n      tableData: [],\r\n    };\r\n  },\r\n  methods: {\r\n    initData(data) {\r\n      this.tableData = data;\r\n    },\r\n    submit() {\r\n      const _tableData = this.tableData.map((item) => {\r\n        if (isEmpty(item.label) && isEmpty(item.value)) {\r\n          this.$message.error(\"规则信息不能为空!\");\r\n          return;\r\n        }\r\n        return {\r\n          label: item.label.trim(),\r\n          value: item.value.trim(),\r\n        };\r\n      });\r\n      console.log(_tableData, \"--_tableData\");\r\n      this.$emit(\"submit\", _tableData);\r\n    },\r\n    add() {\r\n      this.defaultState();\r\n      this.tableData.push({\r\n        label: \"\",\r\n        value: \"\",\r\n        isEdit: true,\r\n      });\r\n      // 设置滚动条位置\r\n      setTimeout(() => {\r\n        // TODO：暂时写死\r\n        this.$refs.table.bodyWrapper.scrollTop = 9999;\r\n      }, 500);\r\n    },\r\n    edit(item, state) {\r\n      this.defaultState();\r\n      this.$set(this.tableData, item.$index, {\r\n        ...item.row,\r\n        isEdit: state,\r\n      });\r\n    },\r\n    del(item) {\r\n      this.tableData.splice(item.$index, 1);\r\n    },\r\n    // 默认为非编辑状态\r\n    defaultState() {\r\n      this.tableData = this.tableData.map((item) => {\r\n        return {\r\n          ...item,\r\n          isEdit: false,\r\n        };\r\n      });\r\n    },\r\n  },\r\n};\r\n</script>\r\n<style lang=\"less\" scoped>\r\n.add-list {\r\n  display: flex;\r\n  justify-content: center;\r\n  margin-top: 4px;\r\n}\r\n</style>"]}]}